ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173
FREE_DAILY_LIMIT=10

# ─── Zugangsschutz (optional) ───
# Sobald ACCESS_GATE_PASS gesetzt ist, fragt die App vor dem Laden ein
# Passwort ab. Passwort ändern = sofort alle alten Zugänge sperren:
#   fly secrets set ACCESS_GATE_PASS="neuesPasswort" -a smart-meal
# GATE_SECRET ist ein langes Zufalls-Secret für die Cookie-Signatur (einmalig).
ACCESS_GATE_PASS=
GATE_SECRET=

# ─── App-Store-Bypass (optional) ───
# APP_BYPASS_TOKEN lässt native Store-Apps (TWA/iOS) den Access-Gate passieren.
# Nur in fly secrets setzen — NIEMALS als VITE_APP_TOKEN in einen Web-Build baken.
# Für Capacitor/native Builds: zur Build-Zeit als VITE_APP_TOKEN injizieren und
# sicherstellen, dass der Web-Build-Workflow diese Variable NICHT setzt.
APP_BYPASS_TOKEN=
