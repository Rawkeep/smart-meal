ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173
FREE_DAILY_LIMIT=10

# ─── Zugangsschutz / Paywall (optional) ───
# Das Gate ist aktiv, sobald ACCESS_CODES ODER ACCESS_GATE_PASS gesetzt ist.
#
# ACCESS_CODES = per-Käufer-Zugangscodes (kommagetrennt). Jeder Käufer bekommt
# einen eigenen Code; jeder ist EINZELN widerrufbar (Code aus der Liste streichen
# + erneut setzen → nur dessen Sitzungen enden, andere bleiben gültig).
#   node scripts/gen-codes.mjs 20            # Codes erzeugen
#   fly secrets set ACCESS_CODES="SMEAL-AAAA-BBBB,SMEAL-CCCC-DDDD" -a smart-meal
ACCESS_CODES=
# ACCESS_GATE_PASS = optionales, geteiltes Einzel-Passwort (Abwärtskompat).
ACCESS_GATE_PASS=
# GATE_SECRET = langes Zufalls-Secret für die Cookie-Signatur. ZWINGEND setzen
# und STABIL halten, damit (a) Cookies Deploys überleben und (b) Widerruf eines
# einzelnen Codes nicht alle abmeldet:
#   fly secrets set GATE_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") -a smart-meal
GATE_SECRET=

# ─── App-Store-Bypass (optional) ───
# APP_BYPASS_TOKEN lässt native Store-Apps (TWA/iOS) den Access-Gate passieren.
# Nur in fly secrets setzen — NIEMALS als VITE_APP_TOKEN in einen Web-Build baken.
# Für Capacitor/native Builds: zur Build-Zeit als VITE_APP_TOKEN injizieren und
# sicherstellen, dass der Web-Build-Workflow diese Variable NICHT setzt.
APP_BYPASS_TOKEN=
