ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173
FREE_DAILY_LIMIT=10

# ─── Zugangsschutz (optional) ───
# Sobald ACCESS_GATE_PASS gesetzt ist, fragt die App vor dem Laden ein
# Passwort ab. Passwort ändern = sofort alle alten Zugänge sperren:
#   fly secrets set ACCESS_GATE_PASS="neuesPasswort" -a smart-meal
# GATE_SECRET ist ein langes Zufalls-Secret für die Cookie-Signatur (einmalig).
ACCESS_GATE_PASS=
GATE_SECRET=
