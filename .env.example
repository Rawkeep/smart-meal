ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173
FREE_DAILY_LIMIT=10

# ─── Modell-Routing (optional) ───
# Einzel-Vorschlag nutzt das schnelle Modell, Wochenplan das stärkere.
# Defaults: Haiku 4.5 (schnell) bzw. Sonnet 4 (Qualität). Nur setzen zum Übersteuern.
MODEL_FAST=claude-haiku-4-5-20251001
MODEL_SMART=claude-sonnet-4-20250514

# ─── BYOK-Provider-Routing (optional) ───
# Eigener Key der Nutzer wird am Präfix erkannt: AIza…→Gemini (Gratis-Tier),
# sk-…→OpenAI, sonst→Anthropic. Modelle der Nicht-Anthropic-Anbieter hier setzbar.
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# ─── Datenbank (SQLite) ───
# Pfad zur SQLite-DB (Käufe, ausgegebene Codes, Freemium-Zähler). In Produktion
# auf das Fly-Volume legen: DB_PATH=/data/smartmeal.db. Lokal Default ./data/smartmeal.db.
DB_PATH=./data/smartmeal.db

# ─── Stripe (automatischer Bezahl→Code-Flow) ───
# STRIPE_SECRET_KEY: verifiziert die Checkout-Session auf /buy/success.
# STRIPE_WEBHOOK_SECRET: signiert den Webhook (Wahrheitsquelle für Käufe/Erstattungen).
#   Endpoint in Stripe anlegen: https://smartmeal.rawkeep.com/api/stripe/webhook
#   Events: checkout.session.completed, charge.refunded, charge.dispute.created
#   fly secrets set STRIPE_SECRET_KEY=sk_live_... STRIPE_WEBHOOK_SECRET=whsec_... -a smart-meal
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── E-Mail (Code-Versand nach Kauf, optional) ───
# Resend-API-Key + verifizierter Absender. Ohne Key wird keine Mail verschickt
# (der Code erscheint trotzdem auf der Erfolgsseite).
#   fly secrets set RESEND_API_KEY=re_... MAIL_FROM="Smart Meal <hi@deine-domain>" -a smart-meal
RESEND_API_KEY=
MAIL_FROM=Smart Meal <onboarding@resend.dev>

# ─── Zugangsschutz / Paywall (optional) ───
# Das Gate ist aktiv, sobald ACCESS_CODES ODER ACCESS_GATE_PASS gesetzt ist.
#
# ACCESS_CODES = per-Käufer-Zugangscodes (kommagetrennt). Jeder Käufer bekommt
# einen eigenen Code; jeder ist EINZELN widerrufbar (Code aus der Liste streichen
# + erneut setzen → nur dessen Sitzungen enden, andere bleiben gültig).
#   node scripts/gen-codes.mjs 20            # Codes erzeugen
#   fly secrets set ACCESS_CODES="SMEAL-AAAA-BBBB,SMEAL-CCCC-DDDD" -a smart-meal
ACCESS_CODES=
# ACCESS_GATE_PASS = optionales, geteiltes Einzel-Passwort (Abwärtskompat).
ACCESS_GATE_PASS=
# GATE_SECRET = langes Zufalls-Secret für die Cookie-Signatur. ZWINGEND setzen
# und STABIL halten, damit (a) Cookies Deploys überleben und (b) Widerruf eines
# einzelnen Codes nicht alle abmeldet:
#   fly secrets set GATE_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") -a smart-meal
GATE_SECRET=

# ─── App-Store-Bypass (optional) ───
# APP_BYPASS_TOKEN lässt native Store-Apps (TWA/iOS) den Access-Gate passieren.
# Nur in fly secrets setzen — NIEMALS als VITE_APP_TOKEN in einen Web-Build baken.
# Für Capacitor/native Builds: zur Build-Zeit als VITE_APP_TOKEN injizieren und
# sicherstellen, dass der Web-Build-Workflow diese Variable NICHT setzt.
APP_BYPASS_TOKEN=
